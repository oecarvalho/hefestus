generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id String @id @default(cuid())
  jobTitle String
  nameEnterprise String
  workModel String
  description String
  date DateTime @default(now())
  status String @default("aplicado")
  
  extractedSkills Json?

  @@map("job")
}

model Curriculum{
  id String @id @default(cuid())
  userId String @unique
  
  name String
  email String
  phoneNumber String

  birthday DateTime

  linkedin String
  portfolio String

  resume String

  experiences Experience[]
  educations Education[]
  projects Project[]
  languages Language[]

  skills String[]
  tools String[]

  createdAt DateTime @default(now())

  @@map("curriculums")
}

model Experience {
  id                String      @id @default(cuid())

  enterpriseName    String
  job               String

  startMonth        String
  startYear         String

  endMonth          String?
  endYear           String?

  jobDescription    String
  jobLocalization   String

  curriculumId      String
  curriculum        Curriculum @relation(fields: [curriculumId], references: [id])

  @@map("experiences")
}

model Education {
  id               String      @id @default(cuid())

  institutionName  String
  title            String

  startMonth       String
  startYear        String

  endMonth         String?
  endYear          String?

  description      String

  curriculumId     String
  curriculum       Curriculum @relation(fields: [curriculumId], references: [id])

  @@map("educations")
}

model Project {
  id                  String      @id @default(cuid())

  projectName         String
  projectLink         String
  projectDescription  String

  curriculumId        String
  curriculum          Curriculum @relation(fields: [curriculumId], references: [id])

  @@map("projects")
}

model Language {
  id            String      @id @default(cuid())

  language      String
  level         String

  curriculumId  String
  curriculum    Curriculum @relation(fields: [curriculumId], references: [id])

  @@map("languages")
}