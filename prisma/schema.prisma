generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  password String
  name String?
  createdAt DateTime @default(now())

  curriculum Curriculum?
  jobs Job[]
  marketStudies MarketStudy[]

  @@map("users")
}

model Job {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle String
  nameEnterprise String
  workModel String
  description String
  date DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  status String @default("aplicado")
  
  extractedSkills Json?

  // Novos campos para gerenciamento de inatividade
  lastActivityAt DateTime @default(now())
  alertCycle Int @default(0)
  autoCanceledAlertPending Boolean @default(false)

  activities JobActivity[]

  @@map("job")
}

model JobActivity {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type        String   // 'status_change', 'custom_activity', 'callback_received', 'interview', 'technical_test', 'reactivation', 'auto_canceled'
  description String
  date        DateTime @default(now())

  @@map("job_activities")
}

model Curriculum{
  id String @id @default(cuid())
  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name String
  email String
  phoneNumber String

  birthday DateTime?

  linkedin String
  portfolio String

  resume String

  experiences Experience[]
  educations Education[]
  projects Project[]
  languages Language[]

  skills String[]
  tools String[]

  createdAt DateTime @default(now())

  @@map("curriculums")
}

model Experience {
  id                String      @id @default(cuid())

  enterpriseName    String
  job               String

  startMonth        String
  startYear         String

  endMonth          String?
  endYear           String?

  jobDescription    String
  jobLocalization   String

  curriculumId      String
  curriculum        Curriculum @relation(fields: [curriculumId], references: [id])

  @@map("experiences")
}

model Education {
  id               String      @id @default(cuid())

  institutionName  String
  title            String

  startMonth       String
  startYear        String

  endMonth         String?
  endYear          String?

  description      String

  curriculumId     String
  curriculum       Curriculum @relation(fields: [curriculumId], references: [id])

  @@map("educations")
}

model Project {
  id                  String      @id @default(cuid())

  projectName         String
  projectLink         String
  projectDescription  String

  curriculumId        String
  curriculum          Curriculum @relation(fields: [curriculumId], references: [id])

  @@map("projects")
}

model Language {
  id            String      @id @default(cuid())

  language      String
  level         String

  curriculumId  String
  curriculum    Curriculum @relation(fields: [curriculumId], references: [id])

  @@map("languages")
}

model MarketStudy {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
  vacancies   MarketVacancy[]

  @@map("market_studies")
}

model MarketVacancy {
  id            String      @id @default(cuid())
  studyId       String
  study         MarketStudy @relation(fields: [studyId], references: [id], onDelete: Cascade)
  enterprise    String
  role          String
  url           String?
  description   String
  extractedData Json?       // Dados estruturados extraídos pela IA
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt

  @@map("market_vacancies")
}